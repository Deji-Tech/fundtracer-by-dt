{
    "name": "@fundtracer/server",
    "version": "1.0.0",
    "description": "FundTracer API Server - Handles auth, rate limiting, and secure API key management",
    "main": "dist/index.js",
    "scripts": {
        "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/index.js && esbuild src/functions/api.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/functions/api.js",
        "start": "node dist/index.js",
        "dev": "tsx watch src/index.ts"
    },
    "dependencies": {
        "@fundtracer/core": "*",
        "@lemonsqueezy/lemonsqueezy.js": "^4.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/nodemailer": "^7.0.11",
        "bcryptjs": "^2.4.3",
        "cheerio": "^1.1.2",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "encoding": "^0.1.13",
        "ethers": "^6.16.0",
        "express": "^4.18.2",
        "express-rate-limit": "^7.5.1",
        "firebase-admin": "^12.0.0",
        "groq": "^3.99.0",
        "helmet": "^7.2.0",
        "jsonwebtoken": "^9.0.3",
        "node-fetch": "^2.7.0",
        "nodemailer": "^6.10.1",
        "qrcode": "^1.5.4",
        "resend": "^6.9.3",
        "serverless-http": "^4.0.0",
        "speakeasy": "^2.0.0",
        "telegraf": "^4.16.3"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.0",
        "@types/qrcode": "^1.5.5",
        "esbuild": "^0.21.5",
        "tsx": "^4.7.0",
        "typescript": "^5.3.0"
    }
}
