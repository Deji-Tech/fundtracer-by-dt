# Server Environment Variables

# Firebase Admin SDK Configuration
# Option 1: Base64 encoded service account JSON (recommended for production)
# FIREBASE_SERVICE_ACCOUNT_BASE64=your_base64_encoded_service_account

# Option 2: Path to service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=./config/firebase-service-account.json

# Option 3: Individual credentials
FIREBASE_PROJECT_ID=fundtracer-by-dt
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@fundtracer-by-dt.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=your_private_key_here

# JWT Secret
JWT_SECRET=your-jwt-secret-change-this-in-production

# API Configuration
PORT=3000
NODE_ENV=development

# Rate Limiting
FREE_DAILY_LIMIT=7

# Alchemy (for validation)
ALCHEMY_API_KEY=your_alchemy_key_here

# Email Configuration (Gmail)
EMAIL_USER=your-email@gmail.com
# For Gmail, use an App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
# Note: Remove spaces from the App Password (e.g., "abcd efgh ijkl mnop" -> "abcdefghijklmnop")
EMAIL_PASS=your-app-password-here-no-spaces

# OAuth Configuration (Google/Twitter) - Hides API keys from users
# Get Google credentials: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must match exactly what's in Google Cloud Console
GOOGLE_REDIRECT_URI=https://www.fundtracer.xyz/api/auth/google/callback

# Get Twitter credentials: https://developer.twitter.com/
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret
# Must match exactly what's in Twitter Developer Portal
TWITTER_REDIRECT_URI=https://www.fundtracer.xyz/api/auth/twitter/callback

# Frontend URL for OAuth callbacks
FRONTEND_URL=https://www.fundtracer.xyz
