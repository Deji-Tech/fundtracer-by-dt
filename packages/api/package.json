{
  "name": "@fundtracer/api",
  "version": "1.0.1",
  "description": "Official JavaScript/TypeScript SDK for FundTracer API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "test": "vitest"
  },
  "keywords": [
    "fundtracer",
    "blockchain",
    "crypto",
    "wallet",
    "analytics",
    "ethereum",
    "api"
  ],
  "author": "FundTracer",
  "license": "MIT",
  "peerDependencies": {
    "typescript": ">=4.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Deji-Tech/fundtracer-by-dt"
  }
}
