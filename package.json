{
  "name": "fundtracer",
  "version": "1.0.0",
  "description": "FundTracer by DT - Blockchain wallet analysis tool",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/server",
    "packages/web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@fundtracer/web",
    "dev:server": "npm run dev --workspace=@fundtracer/server",
    "build": "cd packages/web && npm install && npm run build",
    "build:server": "npm install && npm run build --workspace=fundtracer-core && npm run build --workspace=@fundtracer/server",
    "cli": "npm run start --workspace=fundtracer-cli",
    "video": "npm run start --workspace=@fundtracer/video",
    "test": "npm run test --workspaces --if-present",
    "publish:cli": "cd packages/cli && npm publish"
  },
  "keywords": [
    "blockchain",
    "ethereum",
    "wallet",
    "analysis",
    "fundtracer"
  ],
  "author": "DT",
  "license": "MIT",
  "dependencies": {
    "@privy-io/react-auth": "^3.17.0",
    "@tanstack/react-query": "^5.0.0",
    "esbuild": "^0.21.5",
    "firebase": "^12.7.0",
    "firebase-admin": "^13.6.0",
    "typescript": "^5.3.0",
    "uuid": "^9.0.0",
    "viem": "^2.0.0",
    "wagmi": "^2.5.0"
  },
  "devDependencies": {
    "@types/cytoscape": "^3.21.9"
  }
}
