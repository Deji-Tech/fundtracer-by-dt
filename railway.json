{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd fundtracer-by-dt/packages/core && npm install && npm run build && cd ../server && npm install",
    "installCommand": "cd fundtracer-by-dt/packages/server && npm install"
  },
  "deploy": {
    "startCommand": "cd fundtracer-by-dt/packages/server && node dist/index.js",
    "healthcheckPath": "/health",
    "healthcheckInterval": 30
  }
}
