{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "buildCommand": "npm run build --workspace=fundtracer-core && npm run build --workspace=@fundtracer/server"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "node packages/server/dist/index.js",
    "port": 8080
  }
}
